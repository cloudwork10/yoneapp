# ===========================================
# YONE Backend - Environment Variables
# ===========================================
# نسخ الملف إلى config.env أو .env وتعبئة القيم
# Copy this file to config.env or .env and fill in values

# ----- Server -----
NODE_ENV=development
PORT=3000
API_PORT=3000

# عنوان الباك اند كما يظهر للمستخدم (لروابط الصور/الفيديو)
# في الإنتاج: https://api.yourdomain.com
BASE_URL=http://localhost:3000

# ----- Database -----
# السيرفر يقرأ DB_CONNECTION_STRING (مهم)
# بعض السكربتات قد تستخدم MONGODB_URI
DB_CONNECTION_STRING=mongodb://localhost:27017/yoneapp
MONGODB_URI=mongodb://localhost:27017/yoneapp

# ----- JWT -----
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ----- CORS (للإنتاج فقط) -----
# عناوين مسموح لها بطلب الـ API، مفصولة بفاصلة
# مثال: https://yourapp.com,https://www.yourapp.com
# ALLOWED_ORIGINS=https://yourapp.com

# ----- Rate Limiting (اختياري - في الإنتاج) -----
# RATE_LIMIT_GENERAL_MAX=300
# RATE_LIMIT_PUBLIC_MAX=500
# RATE_LIMIT_AUTH_MAX=20
# RATE_LIMIT_UPLOAD_MAX=30
# RATE_LIMIT_API_MAX=400

# ----- Paymob -----
PAYMOB_BASE_URL=https://accept.paymob.com/api
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_INTEGRATION_ID_CARD=123456
PAYMOB_IFRAME_ID=123456
PAYMOB_HMAC_SECRET=your_hmac_secret

# ----- Optional -----
MAX_FILE_SIZE=10mb
LOG_LEVEL=info
CORS_CREDENTIALS=false
